#Question 1: Prim's Algorithm
def prim(graph,V):
  selected=[False]*V
  selected[0]=True
  cost=0
  print("Edge:weight")
  for _ in range(V-1):
    minimum=float('inf')
    x=y=0
    for i in range(V):
      if selected[i]:
        for j in range(V):
          if not selected[j] and graph[i][j]:
            if graph[i][j]<minimum:
              minimum=graph[i][j]
              x,y=i,j
    print(x, "-", y, ":" ,graph[x][y])
    cost+=graph[x][y]
    selected[y]=True
  print("Minimum Cost=",cost)
