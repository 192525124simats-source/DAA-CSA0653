#Question 2: Kruskal's Algorithm

def kruskal(edges):
    edges.sort(key=lambda x: x[2])
    cost = 0
    print("Edges in MST:")
    for edge in edges[:3]:
      u, v, w = edge
      print(u, "-", v, "=", w)
      cost += w
    print("Minimum Cost =", cost)
edges = [
    (0, 1, 2),
